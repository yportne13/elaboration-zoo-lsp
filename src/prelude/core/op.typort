def outParam[A](a: A): A = a

trait Add[T, O: outParam(Type 0)] {
    def +(that: T): O
}

trait Sub[T, O: outParam(Type 0)] {
    def -(that: T): O
}

trait Mul[T, O: outParam(Type 0)] {
    def *(that: T): O
}

trait Div[T, O: outParam(Type 0)] {
    def /(that: T): O
}

trait And[T, O: outParam(Type 0)] {
    def &(that: T): O
}

trait Or[T, O: outParam(Type 0)] {
    def |(that: T): O
}

trait Xor[T, O: outParam(Type 0)] {
    def ^(that: T): O
}

impl Add[String, String] for String {
    def +(that: String): String = string_concat this that
}

trait Into[O: outParam(Type 0)] {
    def into: O
}

impl[T] Into[T] for T {
    def into: T = this
}

trait Equal[T, O: outParam(Type 0)] {
    def ===(that: T): O
    def =/=(that: T): O
}

trait Compare[T, O: outParam(Type 0)] {
    def <(that: T): O
    def <=(that: T): O
    def >(that: T): O
    def >=(that: T): O
}

trait Neg {
    def - : Self
}

trait Default {
    def default: Self
}

struct Product[A, B] {
    fst: A
    snd: B
}

def id[A](x: A): A = x

def const[A, B](x: A, y: B): A = x

def flip[A, B, C](f: A -> B -> C, x: B, y: A): C = f y x

def compose[A, B, C](f: B -> C, g: A -> B, x: A): C = f (g x)

trait Not {
    def ! : Self
}

trait Rem[T, O: outParam(Type 0)] {
    def %(that: T): O
}

impl[A, B] Product[A, B] {
    def swap: Product[B, A] = new Product(this.snd, this.fst)
    def map_first[C](f: A -> C): Product[C, B] = new Product(f this.fst, this.snd)
    def map_second[C](f: B -> C): Product[A, C] = new Product(this.fst, f this.snd)
}

def curry[A, B, C](f: Product[A, B] -> C, a: A, b: B): C = f (new Product(a, b))

def uncurry[A, B, C](f: A -> B -> C, p: Product[A, B]): C = f p.fst p.snd

trait Clone {
    def clone: Self
}

// ---------- Unit ----------

enum Unit {
    unit
}

// ---------- Tuple types ----------
// Syntactic sugar: (A, B) desugars to Tuple2[A, B]
// Field access: t._1, t._2, ...
// Supported up to Tuple8 for common use cases.

struct Tuple2[A, B] {
    _1: A
    _2: B
}

struct Tuple3[A, B, C] {
    _1: A
    _2: B
    _3: C
}

struct Tuple4[A, B, C, D] {
    _1: A
    _2: B
    _3: C
    _4: D
}

struct Tuple5[A, B, C, D, E] {
    _1: A
    _2: B
    _3: C
    _4: D
    _5: E
}

struct Tuple6[A, B, C, D, E, F] {
    _1: A
    _2: B
    _3: C
    _4: D
    _5: E
    _6: F
}

struct Tuple7[A, B, C, D, E, F, G] {
    _1: A
    _2: B
    _3: C
    _4: D
    _5: E
    _6: F
    _7: G
}

struct Tuple8[A, B, C, D, E, F, G, H] {
    _1: A
    _2: B
    _3: C
    _4: D
    _5: E
    _6: F
    _7: G
    _8: H
}
